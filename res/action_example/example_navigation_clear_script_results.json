{
    "config": {
        "only-validate-config-files": false,
        "delay-time-before-end": 3000,
        "max-action-page-tries": 2
    },
    "navigation": [
        {
            "type": "page",
            "url": "https://www.gmail.com",
            "delay-time-before-next": 100,
            "elements": [
                {
                    "type": "dom-element",
                    "process-as-list": false,
                    "id": null,
                    "name": null,
                    "xpath": "//div//details//summary[contains(@data-g-action, 'create an account')]",
                    "actions": [
                        {
                            "type": "clic",
                            "delay-time-before-next": 100
                        }
                    ]
                },
                {
                    "type": "dom-element",
                    "process-as-list": false,
                    "id": null,
                    "name": null,
                    "xpath": "//nav[contains(@class,'dropdown-menu')]//a",
                    "actions": [
                        {
                            "type": "clic",
                            "delay-time-before-next": 100
                        },
                        {
                            "type": "wait-page-load",
                            "timeout": 30000,
                            "delay-time-before-next": 1000
                        }
                    ]
                },
                {
                    "type": "dom-element",
                    "process-as-list": true,
                    "id": null,
                    "name": null,
                    "xpath": "//input[@type!='hidden']",
                    "actions": [
                        {
                            "type": "script",
                            "script": [
                                "return arguments[0].id;"
                            ],
                            "delay-time-before-next": 100
                        },
                        {
                            "type": "set-text",
                            "text": "%scriptResult[0]%",
                            "clear-before-set": true,
                            "delay-time-before-next": 100
                        },
                        {
                            "type": "clear-script-results",
                            "delay-time-before-next": 100
                        }
                    ]
                }
            ]
        }
    ]
}